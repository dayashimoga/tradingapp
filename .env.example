# =============================================================================
# TradingBot Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# =============================================================================

# --- Alpaca API (US Stocks) ---
TRADINGBOT_ALPACA_API_KEY=your_alpaca_api_key
TRADINGBOT_ALPACA_SECRET_KEY=your_alpaca_secret_key
TRADINGBOT_ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- CCXT / Crypto Exchange ---
TRADINGBOT_CCXT_EXCHANGE=binance
TRADINGBOT_CCXT_API_KEY=your_exchange_api_key
TRADINGBOT_CCXT_SECRET=your_exchange_secret

# --- Telegram Alerts ---
TRADINGBOT_TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TRADINGBOT_TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- Email Alerts ---
TRADINGBOT_EMAIL_SMTP_HOST=smtp.gmail.com
TRADINGBOT_EMAIL_SMTP_PORT=587
TRADINGBOT_EMAIL_USERNAME=your_email@gmail.com
TRADINGBOT_EMAIL_PASSWORD=your_app_password
TRADINGBOT_EMAIL_RECIPIENT=alerts@yourdomain.com

# --- Database ---
TRADINGBOT_DATABASE_URL=sqlite+aiosqlite:///./tradingbot.db

# --- Logging ---
TRADINGBOT_LOG_LEVEL=INFO
TRADINGBOT_LOG_FORMAT=json
